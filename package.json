{
  "name": "cloudev",
  "displayName": "Cloudev",
  "description": "Manage cloud development environments (Ona/Gitpod, Codespaces) from VS Code",
  "version": "0.5.3",
  "publisher": "Yanix",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": ["ui"],
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YanxiChen-gh/Cloudev"
  },
  "license": "MIT",
  "keywords": [
    "cloud",
    "development",
    "environment",
    "gitpod",
    "codespaces",
    "port-forwarding",
    "remote"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cloudev",
          "title": "Cloudev",
          "icon": "$(cloud)"
        }
      ]
    },
    "views": {
      "cloudev": [
        {
          "id": "cloudev.environments",
          "name": "Environments"
        }
      ]
    },
    "commands": [
      {
        "command": "cloudev.createEnvironment",
        "category": "Cloudev",
        "title": "Create Environment",
        "icon": "$(add)"
      },
      {
        "command": "cloudev.startEnvironment",
        "category": "Cloudev",
        "title": "Start",
        "icon": "$(play)"
      },
      {
        "command": "cloudev.stopEnvironment",
        "category": "Cloudev",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "cloudev.restartEnvironment",
        "category": "Cloudev",
        "title": "Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "cloudev.deleteEnvironment",
        "category": "Cloudev",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "cloudev.startPortForwarding",
        "category": "Cloudev",
        "title": "Forward Ports",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "cloudev.stopPortForwarding",
        "category": "Cloudev",
        "title": "Stop Forwarding",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "cloudev.openInNewWindow",
        "category": "Cloudev",
        "title": "Open in New Window",
        "icon": "$(remote-explorer)"
      },
      {
        "command": "cloudev.refreshEnvironments",
        "category": "Cloudev",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cloudev.switchPortForwarding",
        "category": "Cloudev",
        "title": "Switch Port Forwarding Target"
      },
      {
        "command": "cloudev.startDaemon",
        "category": "Cloudev",
        "title": "Start Daemon"
      },
      {
        "command": "cloudev.viewDaemonLog",
        "category": "Cloudev",
        "title": "View Daemon Log"
      },
      {
        "command": "cloudev.envActions",
        "category": "Cloudev",
        "title": "Environment Actions"
      },
      {
        "command": "cloudev.copyEnvInfo",
        "category": "Cloudev",
        "title": "Copy Details",
        "icon": "$(copy)"
      },
      {
        "command": "cloudev.openPort",
        "category": "Cloudev",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "cloudev.copyPortUrl",
        "category": "Cloudev",
        "title": "Copy URL"
      },
      {
        "command": "cloudev.copyPublicUrl",
        "category": "Cloudev",
        "title": "Copy Public URL"
      },
      {
        "command": "cloudev.openInDashboard",
        "category": "Cloudev",
        "title": "Open in Dashboard",
        "icon": "$(globe)"
      },
      {
        "command": "cloudev.copySshCommand",
        "category": "Cloudev",
        "title": "Copy SSH Command",
        "icon": "$(terminal)"
      },
      {
        "command": "cloudev.addFavorite",
        "category": "Cloudev",
        "title": "Add to Favorites",
        "icon": "$(star-empty)"
      },
      {
        "command": "cloudev.removeFavorite",
        "category": "Cloudev",
        "title": "Remove from Favorites",
        "icon": "$(star-full)"
      },
      {
        "command": "cloudev.copyPortInfo",
        "category": "Cloudev",
        "title": "Copy Details"
      },
      {
        "command": "cloudev.sideBySide",
        "category": "Cloudev",
        "title": "Side-by-Side Web Compare",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "cloudev.stopSideBySide",
        "category": "Cloudev",
        "title": "Stop Side-by-Side"
      },
      {
        "command": "cloudev.addCompare",
        "category": "Cloudev",
        "title": "Web Compare",
        "icon": "$(git-compare)"
      },
      {
        "command": "cloudev.removeCompare",
        "category": "Cloudev",
        "title": "Remove Web Compare",
        "icon": "$(close)"
      },
      {
        "command": "cloudev.openCompare",
        "category": "Cloudev",
        "title": "Open Web Compare",
        "icon": "$(link-external)"
      },
      {
        "command": "cloudev.syncHistory",
        "category": "Cloudev",
        "title": "Sync Shell History",
        "icon": "$(history)"
      },
      {
        "command": "cloudev.clearHistory",
        "category": "Cloudev",
        "title": "Clear Shell History"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cloudev.createEnvironment",
          "when": "view == cloudev.environments",
          "group": "navigation"
        },
        {
          "command": "cloudev.refreshEnvironments",
          "when": "view == cloudev.environments",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cloudev.startEnvironment",
          "when": "view == cloudev.environments && viewItem =~ /^environment-stopped/",
          "group": "inline@1"
        },
        {
          "command": "cloudev.openInNewWindow",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "inline@1"
        },
        {
          "command": "cloudev.startPortForwarding",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running/ && !cloudev.isForwarding",
          "group": "inline@2"
        },
        {
          "command": "cloudev.addCompare",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running/ && cloudev.isForwarding",
          "group": "inline@2"
        },
        {
          "command": "cloudev.stopPortForwarding",
          "when": "view == cloudev.environments && viewItem =~ /^environment-forwarding/",
          "group": "inline@2"
        },
        {
          "command": "cloudev.removeCompare",
          "when": "view == cloudev.environments && viewItem =~ /^environment-comparing/",
          "group": "inline@2"
        },
        {
          "command": "cloudev.addFavorite",
          "when": "view == cloudev.environments && viewItem =~ /^environment-[a-z]+$/",
          "group": "inline@3"
        },
        {
          "command": "cloudev.removeFavorite",
          "when": "view == cloudev.environments && viewItem =~ /\\.fav$/ && viewItem =~ /^environment-/",
          "group": "inline@3"
        },
        {
          "command": "cloudev.openPort",
          "when": "view == cloudev.environments && viewItem =~ /^port/",
          "group": "inline@1"
        },
        {
          "command": "cloudev.addFavorite",
          "when": "view == cloudev.environments && viewItem =~ /^port(-with-url)?$/",
          "group": "inline@2"
        },
        {
          "command": "cloudev.removeFavorite",
          "when": "view == cloudev.environments && viewItem =~ /\\.fav$/ && viewItem =~ /^port/",
          "group": "inline@2"
        },
        {
          "command": "cloudev.startEnvironment",
          "when": "view == cloudev.environments && viewItem =~ /^environment-stopped/",
          "group": "1_lifecycle@1"
        },
        {
          "command": "cloudev.stopEnvironment",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "1_lifecycle@2"
        },
        {
          "command": "cloudev.restartEnvironment",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "1_lifecycle@3"
        },
        {
          "command": "cloudev.startPortForwarding",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running/",
          "group": "2_ports@1"
        },
        {
          "command": "cloudev.addCompare",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running/ && cloudev.isForwarding",
          "group": "2_ports@2"
        },
        {
          "command": "cloudev.stopPortForwarding",
          "when": "view == cloudev.environments && viewItem =~ /^environment-forwarding/",
          "group": "2_ports@1"
        },
        {
          "command": "cloudev.removeCompare",
          "when": "view == cloudev.environments && viewItem =~ /^environment-comparing/",
          "group": "2_ports@1"
        },
        {
          "command": "cloudev.openCompare",
          "when": "view == cloudev.environments && viewItem =~ /^environment-comparing/",
          "group": "2_ports@2"
        },
        {
          "command": "cloudev.openInNewWindow",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "3_connect@1"
        },
        {
          "command": "cloudev.openInDashboard",
          "when": "view == cloudev.environments && viewItem =~ /^environment-/",
          "group": "3_connect@2"
        },
        {
          "command": "cloudev.copyEnvInfo",
          "when": "view == cloudev.environments && viewItem =~ /^environment-/",
          "group": "4_copy@1"
        },
        {
          "command": "cloudev.copySshCommand",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "4_copy@2"
        },
        {
          "command": "cloudev.addFavorite",
          "when": "view == cloudev.environments && viewItem =~ /^environment-[a-z]+$/",
          "group": "4_copy@3"
        },
        {
          "command": "cloudev.removeFavorite",
          "when": "view == cloudev.environments && viewItem =~ /\\.fav$/ && viewItem =~ /^environment-/",
          "group": "4_copy@3"
        },
        {
          "command": "cloudev.syncHistory",
          "when": "view == cloudev.environments && viewItem =~ /^environment-running|^environment-forwarding|^environment-comparing/",
          "group": "4b_history@1"
        },
        {
          "command": "cloudev.deleteEnvironment",
          "when": "view == cloudev.environments && viewItem =~ /^environment-stopped/",
          "group": "5_danger@1"
        },
        {
          "command": "cloudev.addFavorite",
          "when": "view == cloudev.environments && viewItem =~ /^port(-with-url)?$/",
          "group": "1_port@0"
        },
        {
          "command": "cloudev.removeFavorite",
          "when": "view == cloudev.environments && viewItem =~ /\\.fav$/ && viewItem =~ /^port/",
          "group": "1_port@0"
        },
        {
          "command": "cloudev.openPort",
          "when": "view == cloudev.environments && viewItem =~ /^port/",
          "group": "1_port@1"
        },
        {
          "command": "cloudev.copyPortUrl",
          "when": "view == cloudev.environments && viewItem =~ /^port/",
          "group": "1_port@2"
        },
        {
          "command": "cloudev.copyPortInfo",
          "when": "view == cloudev.environments && viewItem =~ /^port/",
          "group": "1_port@3"
        },
        {
          "command": "cloudev.copyPublicUrl",
          "when": "view == cloudev.environments && viewItem =~ /^port-with-url/",
          "group": "1_port@4"
        }
      ]
    },
    "configuration": {
      "title": "Cloudev",
      "properties": {
        "cloudev.shellHistory.periodicSyncMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-sync shell history every N minutes (0 = disabled). Bidirectional sync with all running environments."
        },
        "cloudev.binaryPaths.gitpod": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the gitpod CLI binary. Leave empty for auto-detection."
        },
        "cloudev.binaryPaths.gh": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the gh (GitHub CLI) binary. Leave empty for auto-detection."
        },
        "cloudev.binaryPaths.ssh": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the ssh binary. Leave empty for auto-detection."
        },
        "cloudev.binaryPaths.lsof": {
          "type": "string",
          "default": "",
          "description": "Absolute path to lsof. Leave empty for auto-detection."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
